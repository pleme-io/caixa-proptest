                 arg1: (b, c),\n                        d,\n                        arg3: Wrapper(e),\n                        arg4: [f,\n                        g,\n                        ],\n                        h,\n                        arg6: Point { x, y },\n                    },\n                )|\n            {\n                let result = {};\n                Ok(result)\n            },\n        );\n    match result {\n        Ok(()) => {}\n        Err(e) => panic!(\"{}\", e),\n    }\n}\n"} {:path "proptest-macro/src/property_test/codegen/snapshots/proptest_macro__property_test__codegen__snapshot_tests__return_value.snap"
