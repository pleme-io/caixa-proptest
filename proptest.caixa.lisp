\"1\")]\nstruct L;\n\n#[derive(Debug, Arbitrary)] //~ ERROR: [proptest_derive, E0007]\n#[proptest(regex = \"\\\\d\\\\d\")]\nstruct M();\n\n#[derive(Debug, Arbitrary)] //~ ERROR: [proptest_derive, E0007]\n#[proptest(regex = \"3\")]\nstruct N { field: String }\n\n#[derive(Debug, Arbitrary)] //~ ERROR: [proptest_derive, E0007]\n#[proptest(regex = \"a+\")]\nstruct O(Vec<u8>);\n\n#[derive(Debug, Arbitrary)] //~ ERROR: [proptest_derive, E0007]\n#[proptest(regex = \"b*\")]\nenum P { V1, V2, }\n"} {:path "proptest-derive/tests/compile-fail/E0011-params-variant.rs"
