   :body "// Make sure that code for choosing names for the generated struct is robust against mixtures of\n// ident and non-ident parameter patterns\n\nfn foo(\n    a: i32,\n    (b, c): (i32, i32),\n    d: i32,\n    Wrapper(e): Wrapper<i32>,\n    [f, g]: [i32; 2],\n    h: i32,\n    Point { x, y }: Point,\n) {}\n"} {:path "proptest-macro/src/property_test/codegen/test_data/many_params.rs"
